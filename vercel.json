{
  "version": 2,
  "buildCommand": "echo 'Build complete'",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "GOOGLE_API_KEY": "@google_api_key",
    "HUGGINGFACE_API_KEY": "@huggingface_api_key",
    "NODE_ENV": "production"
  }
}
